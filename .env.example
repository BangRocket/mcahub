# mcadiff-hub configuration. Copy to `.env` and fill in. `.env` is gitignored.
# Anything already set in your shell environment wins over this file.
#
# Leave the OAuth client id/secret blank to keep accounts OFF (open/token mode).
# Set BOTH to turn on GitHub sign-in.

# ---- GitHub sign-in (accounts mode) ----
# Create an OAuth App at https://github.com/settings/developers → "New OAuth App":
#   Homepage URL:               http://localhost:5080
#   Authorization callback URL: http://localhost:5080/auth/callback
# then copy the Client ID and a generated client secret here.
MCAHUB_OAUTH_CLIENT_ID=
MCAHUB_OAUTH_CLIENT_SECRET=

# ---- other OAuth2 providers (optional) ----
# Defaults target GitHub. Override these to use GitLab, Gitea, etc.
#MCAHUB_OAUTH_PROVIDER=github
#MCAHUB_OAUTH_AUTH_URL=https://github.com/login/oauth/authorize
#MCAHUB_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
#MCAHUB_OAUTH_USER_URL=https://api.github.com/user
#MCAHUB_OAUTH_SCOPE=read:user

# ---- storage / network ----
#MCAHUB_DATA=data/repos
#MCAHUB_CACHE=data/cache
#MCAHUB_MAPS=data/maps
#MCAHUB_DB=data/hub.json
#MCAHUB_AUDIT=data/audit.jsonl
#ASPNETCORE_URLS=http://localhost:5080

# ---- resource limits (defense-in-depth; defaults shown) ----
#MCAHUB_MAX_PUSH_BYTES=268435456       # max push body (bytes); larger → 413
#MCAHUB_CACHE_MAX_GB=10                # world-cache size ceiling (LRU eviction past it)
#MCAHUB_MAX_WORLDS_PER_REPO=10         # materialized worlds kept per repo
#MCAHUB_MAP_CACHE_MAX_GB=2             # map (PNG) cache size ceiling
#MCAHUB_MAX_MAPS_PER_REPO=100          # map PNGs kept per repo
#MCAHUB_MAX_MANIFEST_ENTRIES=100000    # refuse to materialize a manifest with more file/dir entries
#MCAHUB_MAX_RENDER_CONCURRENCY=3       # concurrent map renders
#MCAHUB_MAX_RENDER_CHUNKS=10000        # chunks decoded per render (bigger worlds truncate)
#MCAHUB_RENDER_TIMEOUT_SECONDS=30      # hard per-render deadline
#MCAHUB_RATELIMIT_AUTH=20              # auth/token requests per IP per minute (429 past it)
#MCAHUB_RATELIMIT_WRITE=60             # push requests per IP per minute
#MCAHUB_RATELIMIT_RENDER=30            # cold map renders per IP per minute
#MCAHUB_RATELIMIT_READ=300             # read/page requests per IP per minute
#MCAHUB_AUTH_MAX_FAILURES=5            # bad bearer tokens from one IP before a lockout
#MCAHUB_AUTH_LOCKOUT_SECONDS=30        # base lockout (doubles with continued failures)

# A shared/master token. In open mode it gates writes; in accounts mode it's an admin bypass.
#MCAHUB_TOKEN=

# Set to 1 when running behind a TLS-terminating reverse proxy, so the OAuth callback uses https.
# Forwarded headers (proto/host/for) are trusted ONLY from MCAHUB_TRUSTED_PROXY (default loopback) —
# make sure the app port itself is NOT directly reachable, or set the proxy's IP/CIDR explicitly below.
#MCAHUB_BEHIND_PROXY=1
#MCAHUB_TRUSTED_PROXY=127.0.0.1, ::1

# ⚠ Insecure local login at /auth/dev for evaluating accounts without an OAuth app. Never on a public host.
# (The hub refuses to start with this on a non-loopback bind.)
#MCAHUB_DEV_LOGIN=1

# The hub refuses to start in open mode (anonymous read+write) on a non-loopback bind unless you opt in here.
#MCAHUB_I_KNOW_OPEN_MODE_IS_PUBLIC=1

# Let a push to a PRE-EXISTING unowned world claim it (e.g. migrating worlds pushed before accounts).
# Off by default so a signed-up user can't take over a legacy world; enable only during a supervised migration.
#MCAHUB_ADOPT_UNOWNED=1
