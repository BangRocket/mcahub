{
  // markdownlint config for the hub's human-facing docs (README, SECURITY.md, CLAUDE.md).
  // Structural rules stay on; purely stylistic ones that fight normal prose and our table
  // style are off. Mirrors the mcagit core's config.
  "config": {
    "default": true,
    "MD013": false, // line-length — prose wraps freely, code blocks have long lines
    "MD060": false, // table-column-style — we use compact pipe tables
    "MD033": false, // inline HTML — allowed where needed
    "MD041": false  // first-line-heading — README opens with content by design
  },
  // Agent memory, agent/skill definitions, and other tooling markdown under .claude/ are
  // machine-managed and not part of the project's published docs.
  "ignores": [
    ".claude/**",
    "docs/superpowers/**",
    "**/node_modules/**"
  ]
}
